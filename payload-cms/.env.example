# Required in the existing Vercel project: managed Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Required: generate a long random secret, at least 32 characters.
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Same public project and domain: website at /, Payload login at /admin.
PAYLOAD_PUBLIC_SERVER_URL=https://digitale-gewinner.de
PUBLIC_WEBSITE_URL=https://digitale-gewinner.de

# Use true for the first database initialization, then change to false.
PAYLOAD_DB_PUSH=true
