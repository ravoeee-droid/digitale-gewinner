# Required: managed Postgres connection string (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Required: generate a long random secret, at least 32 characters
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Public URL of this separate Payload deployment, for example:
PAYLOAD_PUBLIC_SERVER_URL=https://cms.digitale-gewinner.de

# Optional: the public website URL used in admin preview links
PUBLIC_WEBSITE_URL=https://digitale-gewinner.de
